# ============================================================
# G2B Smart Compare — Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=g2b
POSTGRES_PASSWORD=g2bpassword
POSTGRES_DB=g2b_smart_compare
DATABASE_URL=postgresql://g2b:g2bpassword@localhost:5432/g2b_smart_compare

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PRODUCTS=g2b_products
ELASTICSEARCH_INDEX_VENDORS=g2b_vendors

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_TTL_SEARCH=300
REDIS_TTL_PRODUCT=600
REDIS_TTL_VENDOR=600

# --- Public Data APIs ---
# 공공데이터포털 (data.go.kr) API key
G2B_API_KEY=your_public_data_api_key_here
# 조달데이터허브 bulk data base URL
G2B_DATA_HUB_URL=https://www.g2b.go.kr

# --- Naver Shopping API (for reference prices) ---
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# --- ETL Settings ---
ETL_BATCH_SIZE=1000
ETL_MAX_RETRIES=3
ETL_RETRY_DELAY_MS=1000
ETL_DATA_STALE_HOURS=24

# --- App Settings ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
